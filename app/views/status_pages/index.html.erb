<% content_for(:page_title) { "Status Pages" } %>

<% content_for(:page_actions) do %>
  <%= link_to new_status_page_path, class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    New Status Page
  <% end %>
<% end %>

<div class="space-y-6">
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    <% if @status_pages.any? %>
      <div class="divide-y divide-slate-100">
        <% @status_pages.each do |page| %>
          <div class="flex items-center gap-4 px-6 py-5 hover:bg-slate-50 transition-colors">
            <div class="flex h-12 w-12 items-center justify-center rounded-lg" style="background-color: <%= page.theme_color || '#1F2937' %>20">
              <svg class="h-6 w-6" style="color: <%= page.theme_color || '#1F2937' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
              </svg>
            </div>

            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <%= link_to page.name, status_page_path(page), class: "text-sm font-semibold text-slate-900 hover:text-slate-700" %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= page.published? ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-600' %>">
                  <%= page.published? ? 'Published' : 'Draft' %>
                </span>
              </div>
              <p class="mt-0.5 text-xs text-slate-500">
                /status/<%= page.slug %> &middot; <%= page.monitors.size %> monitors
              </p>
            </div>

            <div class="flex items-center gap-2">
              <% if page.published? %>
                <%= link_to public_status_page_path(page.slug), target: "_blank", class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50 transition-colors" do %>
                  View Public
                <% end %>
              <% end %>
              <%= link_to "Edit", edit_status_page_path(page), class: "rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50 transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3" />
        </svg>
        <p class="mt-3 text-sm font-medium text-slate-500">No status pages yet</p>
        <p class="mt-1 text-xs text-slate-400">Create a public status page for your services</p>
        <%= link_to "Create Status Page", new_status_page_path, class: "mt-4 inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" %>
      </div>
    <% end %>
  </div>
</div>
