<% content_for(:page_title) { @status_page.name } %>

<% content_for(:page_actions) do %>
  <div class="flex items-center gap-2">
    <% if @status_page.published? %>
      <%= link_to public_status_page_path(@status_page.slug), target: "_blank", class: "inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors" do %>
        View Public Page
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      <% end %>
    <% end %>
    <%= link_to "Edit", edit_status_page_path(@status_page), class: "inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors" %>
  </div>
<% end %>

<div class="space-y-8">
  <%# Page Info %>
  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="flex h-14 w-14 items-center justify-center rounded-lg" style="background-color: <%= @status_page.theme_color || '#1F2937' %>20">
        <svg class="h-7 w-7" style="color: <%= @status_page.theme_color || '#1F2937' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3" />
        </svg>
      </div>
      <div>
        <div class="flex items-center gap-3">
          <h2 class="text-xl font-bold text-slate-900"><%= @status_page.name %></h2>
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @status_page.published? ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-600' %>">
            <%= @status_page.published? ? 'Published' : 'Draft' %>
          </span>
        </div>
        <p class="mt-1 text-sm text-slate-500">Public URL: /status/<%= @status_page.slug %></p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-4">
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-sm text-slate-500">Monitors</p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= @monitors.size %></p>
      </div>
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-sm text-slate-500">Layout</p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= @status_page.layout&.capitalize || "Wide" %></p>
      </div>
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-sm text-slate-500">Theme</p>
        <div class="mt-1 flex items-center gap-2">
          <div class="h-6 w-6 rounded" style="background-color: <%= @status_page.theme_color || '#1F2937' %>"></div>
          <span class="text-sm font-medium text-slate-900"><%= @status_page.theme_color || '#1F2937' %></span>
        </div>
      </div>
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-sm text-slate-500">Password</p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= @status_page.password_digest.present? ? 'Yes' : 'No' %></p>
      </div>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-8">
      <%# Monitors %>
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
          <h3 class="text-base font-semibold text-slate-900">Monitors</h3>
        </div>
        <% if @monitors.any? %>
          <div class="divide-y divide-slate-100">
            <% @monitors.each do |monitor| %>
              <div class="flex items-center gap-4 px-6 py-4">
                <div class="h-3 w-3 rounded-full
                  <%= case monitor.status
                      when 'up' then 'bg-emerald-500'
                      when 'down' then 'bg-red-500'
                      when 'paused' then 'bg-amber-500'
                      else 'bg-slate-400'
                      end %>"></div>
                <div class="min-w-0 flex-1">
                  <%= link_to monitor.name, monitor_path(monitor), class: "text-sm font-medium text-slate-900 hover:text-slate-700" %>
                  <p class="text-xs text-slate-500"><%= monitor.url.presence || monitor.hostname.presence || "—" %></p>
                </div>
                <span class="text-sm font-medium
                  <%= case monitor.status
                      when 'up' then 'text-emerald-600'
                      when 'down' then 'text-red-600'
                      else 'text-slate-500'
                      end %>">
                  <%= monitor.status.capitalize %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center">
            <p class="text-sm text-slate-500">No monitors added yet</p>
          </div>
        <% end %>
      </div>

      <%# Active Announcements %>
      <% if @announcements.any? %>
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
          <div class="border-b border-slate-200 px-6 py-4">
            <h3 class="text-base font-semibold text-slate-900">Active Announcements</h3>
          </div>
          <div class="divide-y divide-slate-100">
            <% @announcements.each do |announcement| %>
              <div class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                    <%= case announcement.status
                        when 'investigating' then 'bg-red-100 text-red-800'
                        when 'identified' then 'bg-amber-100 text-amber-800'
                        when 'monitoring' then 'bg-blue-100 text-blue-800'
                        else 'bg-slate-100 text-slate-600'
                        end %>">
                    <%= announcement.status.capitalize %>
                  </span>
                  <span class="text-xs text-slate-500"><%= time_ago_in_words(announcement.started_at) %> ago</span>
                </div>
                <p class="mt-1 text-sm font-medium text-slate-900"><%= announcement.title %></p>
                <p class="mt-1 text-sm text-slate-600"><%= truncate(announcement.content, length: 200) %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="space-y-6">
      <%# Settings %>
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-base font-semibold text-slate-900">Display Settings</h3>
        <dl class="mt-4 space-y-3">
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Show Uptime %</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @status_page.show_uptime_percentage? ? 'Yes' : 'No' %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Show Response Time</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @status_page.show_response_time_graph? ? 'Yes' : 'No' %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Show Monitor URL</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @status_page.show_monitor_url? ? 'Yes' : 'No' %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Show Paused</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @status_page.show_paused_monitors? ? 'Yes' : 'No' %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Sort By</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @status_page.sort_by&.capitalize || "Status" %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">No Index</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @status_page.noindex? ? 'Yes' : 'No' %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
