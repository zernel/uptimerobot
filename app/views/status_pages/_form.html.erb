<%= form_with(model: status_page, class: "space-y-8") do |form| %>
  <% if status_page.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(status_page.errors.count, "error") %> prohibited this status page from being saved:</h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
            <% status_page.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <h3 class="text-base font-semibold text-slate-900">Basic Information</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "My Service Status" %>
      </div>

      <div>
        <%= form.label :slug, "URL Slug", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :slug, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "my-service" %>
      </div>

      <div>
        <%= form.label :logo_url, "Logo URL", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :logo_url, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "https://..." %>
      </div>

      <div>
        <%= form.label :favicon_url, "Favicon URL", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :favicon_url, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "https://..." %>
      </div>
    </div>
  </div>

  <div>
    <h3 class="text-base font-semibold text-slate-900">Appearance</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div>
        <%= form.label :theme_color, class: "block text-sm font-medium text-slate-700" %>
        <%= form.color_field :theme_color, class: "mt-1 block h-10 w-full rounded-lg border border-slate-300 bg-white px-1 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :header_bg_color, "Header Background", class: "block text-sm font-medium text-slate-700" %>
        <%= form.color_field :header_bg_color, class: "mt-1 block h-10 w-full rounded-lg border border-slate-300 bg-white px-1 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :layout, class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :layout, %w[wide centered], {}, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>
    </div>
  </div>

  <div>
    <h3 class="text-base font-semibold text-slate-900">Display Options</h3>
    <div class="mt-4 space-y-3">
      <label class="flex items-center gap-3">
        <%= form.check_box :show_uptime_percentage, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        <span class="text-sm text-slate-700">Show uptime percentage</span>
      </label>
      <label class="flex items-center gap-3">
        <%= form.check_box :show_response_time_graph, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        <span class="text-sm text-slate-700">Show response time graph</span>
      </label>
      <label class="flex items-center gap-3">
        <%= form.check_box :show_monitor_url, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        <span class="text-sm text-slate-700">Show monitor URLs</span>
      </label>
      <label class="flex items-center gap-3">
        <%= form.check_box :show_paused_monitors, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        <span class="text-sm text-slate-700">Show paused monitors</span>
      </label>
      <label class="flex items-center gap-3">
        <%= form.check_box :noindex, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        <span class="text-sm text-slate-700">Hide from search engines</span>
      </label>
      <label class="flex items-center gap-3">
        <%= form.check_box :published, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        <span class="text-sm text-slate-700">Publish (make publicly accessible)</span>
      </label>
    </div>
  </div>

  <div>
    <h3 class="text-base font-semibold text-slate-900">Monitors</h3>
    <p class="mt-1 text-sm text-slate-500">Select which monitors to display on this status page.</p>
    <div class="mt-4 grid gap-2 sm:grid-cols-2">
      <% monitors.each do |monitor| %>
        <label class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3 cursor-pointer hover:bg-slate-50 transition-colors">
          <%= check_box_tag "status_page[monitor_ids][]", monitor.id, status_page.monitor_ids.include?(monitor.id), class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-slate-900"><%= monitor.name %></p>
            <p class="text-xs text-slate-500"><%= monitor.monitor_type.capitalize %></p>
          </div>
          <div class="h-2.5 w-2.5 rounded-full
            <%= case monitor.status
                when 'up' then 'bg-emerald-500'
                when 'down' then 'bg-red-500'
                when 'paused' then 'bg-amber-500'
                else 'bg-slate-400'
                end %>"></div>
        </label>
      <% end %>
    </div>
  </div>

  <div>
    <h3 class="text-base font-semibold text-slate-900">Security</h3>
    <div class="mt-4">
      <%= form.label :password, "Password Protection", class: "block text-sm font-medium text-slate-700" %>
      <%= form.password_field :password, class: "mt-1 block w-full max-w-md rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "Leave blank for no password" %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-slate-200 pt-6">
    <%= link_to "Cancel", status_page.persisted? ? status_page_path(status_page) : status_pages_path, class: "rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors" %>
    <%= form.submit class: "rounded-lg bg-slate-900 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors cursor-pointer" %>
  </div>
<% end %>
