<% content_for(:page_title) { "Maintenance Windows" } %>

<% content_for(:page_actions) do %>
  <%= link_to new_maintenance_window_path, class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Schedule Maintenance
  <% end %>
<% end %>

<div class="space-y-8">
  <%# Active Windows %>
  <% if @active_windows.any? %>
    <div>
      <h2 class="text-base font-semibold text-slate-900 mb-4">Active Now</h2>
      <div class="rounded-xl border border-amber-200 bg-amber-50 shadow-sm">
        <div class="divide-y divide-amber-200">
          <% @active_windows.each do |window| %>
            <%= link_to maintenance_window_path(window), class: "flex items-center gap-4 px-6 py-5 hover:bg-amber-100 transition-colors" do %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-100">
                <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-slate-900"><%= window.name %></p>
                <p class="text-xs text-slate-600">
                  Ends in <%= time_ago_in_words(window.ends_at) %>
                  <% if window.description.present? %> &middot; <%= truncate(window.description, length: 60) %><% end %>
                </p>
              </div>
              <span class="inline-flex items-center rounded-full bg-amber-200 px-2.5 py-0.5 text-xs font-medium text-amber-800">
                Active
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Upcoming Windows %>
  <% if @upcoming_windows.any? %>
    <div>
      <h2 class="text-base font-semibold text-slate-900 mb-4">Upcoming</h2>
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="divide-y divide-slate-100">
          <% @upcoming_windows.each do |window| %>
            <%= link_to maintenance_window_path(window), class: "flex items-center gap-4 px-6 py-5 hover:bg-slate-50 transition-colors" do %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-100">
                <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-slate-900"><%= window.name %></p>
                <p class="text-xs text-slate-500">
                  Starts in <%= time_ago_in_words(window.starts_at) %> &middot; Duration: <%= distance_of_time_in_words(window.starts_at, window.ends_at) %>
                </p>
              </div>
              <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800">
                Upcoming
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# All Windows %>
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 px-6 py-4">
      <h3 class="text-base font-semibold text-slate-900">All Maintenance Windows</h3>
    </div>
    <% if @maintenance_windows.any? %>
      <div class="divide-y divide-slate-100">
        <% @maintenance_windows.each do |window| %>
          <%= link_to maintenance_window_path(window), class: "flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-full
              <%= if window.active?
                  'bg-amber-100'
                elsif window.upcoming?
                  'bg-blue-100'
                else
                  'bg-slate-100'
                end %>">
              <svg class="h-5 w-5
                <%= if window.active?
                    'text-amber-600'
                  elsif window.upcoming?
                    'text-blue-600'
                  else
                    'text-slate-500'
                  end %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-slate-900"><%= window.name %></p>
              <p class="text-xs text-slate-500">
                <%= window.starts_at.strftime('%b %d, %Y %H:%M') %> &mdash; <%= window.ends_at.strftime('%b %d, %Y %H:%M') %>
              </p>
            </div>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= if window.active?
                  'bg-amber-100 text-amber-800'
                elsif window.upcoming?
                  'bg-blue-100 text-blue-800'
                else
                  'bg-slate-100 text-slate-600'
                end %>">
              <%= if window.active?
                  'Active'
                elsif window.upcoming?
                  'Upcoming'
                else
                  'Past'
                end %>
            </span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="mt-3 text-sm font-medium text-slate-500">No maintenance windows</p>
        <p class="mt-1 text-xs text-slate-400">Schedule maintenance to suppress alerts during planned downtime</p>
        <%= link_to "Schedule Maintenance", new_maintenance_window_path, class: "mt-4 inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" %>
      </div>
    <% end %>
  </div>
</div>
