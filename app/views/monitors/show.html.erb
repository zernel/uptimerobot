<% content_for(:page_title) { @monitor.name } %>

<% content_for(:page_actions) do %>
  <div class="flex items-center gap-2">
    <% if @monitor.paused? %>
      <%= button_to "Resume", resume_monitor_path(@monitor), method: :post, class: "inline-flex items-center gap-2 rounded-lg border border-emerald-300 bg-emerald-50 px-4 py-2.5 text-sm font-medium text-emerald-700 hover:bg-emerald-100 transition-colors" %>
    <% else %>
      <%= button_to "Pause", pause_monitor_path(@monitor), method: :post, class: "inline-flex items-center gap-2 rounded-lg border border-amber-300 bg-amber-50 px-4 py-2.5 text-sm font-medium text-amber-700 hover:bg-amber-100 transition-colors" %>
    <% end %>
    <%= link_to "Edit", edit_monitor_path(@monitor), class: "inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors" %>
  </div>
<% end %>

<div class="space-y-8">
  <%# Status Header %>
  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex items-start gap-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-full
          <%= case @monitor.status
              when 'up' then 'bg-emerald-100'
              when 'down' then 'bg-red-100'
              when 'paused' then 'bg-amber-100'
              else 'bg-slate-100'
              end %>">
          <div class="h-4 w-4 rounded-full
            <%= case @monitor.status
                when 'up' then 'bg-emerald-500'
                when 'down' then 'bg-red-500'
                when 'paused' then 'bg-amber-500'
                else 'bg-slate-400'
                end %>"></div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <h2 class="text-xl font-bold text-slate-900"><%= @monitor.name %></h2>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= case @monitor.status
                  when 'up' then 'bg-emerald-100 text-emerald-800'
                  when 'down' then 'bg-red-100 text-red-800'
                  when 'paused' then 'bg-amber-100 text-amber-800'
                  else 'bg-slate-100 text-slate-600'
                  end %>">
              <%= @monitor.status.capitalize %>
            </span>
            <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
              <%= @monitor.monitor_type.upcase %>
            </span>
          </div>
          <p class="mt-1 text-sm text-slate-500"><%= @monitor.url.presence || @monitor.hostname.presence || "No URL configured" %></p>
          <% if @monitor.description.present? %>
            <p class="mt-2 text-sm text-slate-600"><%= @monitor.description %></p>
          <% end %>
        </div>
      </div>

      <div class="flex items-center gap-6">
        <div class="text-center">
          <p class="text-2xl font-bold text-slate-900"><%= @monitor.uptime_24h || "—" %><% if @monitor.uptime_24h %>%<% end %></p>
          <p class="text-xs text-slate-500">24h Uptime</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-slate-900"><%= @monitor.uptime_7d || "—" %><% if @monitor.uptime_7d %>%<% end %></p>
          <p class="text-xs text-slate-500">7d Uptime</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-slate-900"><%= @monitor.uptime_30d || "—" %><% if @monitor.uptime_30d %>%<% end %></p>
          <p class="text-xs text-slate-500">30d Uptime</p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-8">
      <%# Response Time Chart %>
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-base font-semibold text-slate-900">Response Time</h3>
        <div class="mt-4 h-64" data-controller="chart" data-chart-labels-value="<%= @response_time_stats.map { |s| s.period_start.strftime('%H:%M') }.to_json %>" data-chart-data-value="<%= @response_time_stats.map(&:avg_response_time).to_json %>">
          <canvas data-chart-target="canvas"></canvas>
        </div>
      </div>

      <%# Check Results History %>
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
          <h3 class="text-base font-semibold text-slate-900">Check Results</h3>
          <span class="text-xs text-slate-500">Last 100 checks</span>
        </div>
        <div class="divide-y divide-slate-100 max-h-96 overflow-y-auto">
          <% @check_results.each do |result| %>
            <div class="flex items-center gap-4 px-6 py-3">
              <div class="h-2.5 w-2.5 rounded-full <%= result.status == 'up' ? 'bg-emerald-500' : 'bg-red-500' %>"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm text-slate-700">
                  <span class="font-medium"><%= result.status.upcase %></span>
                  <% if result.response_time %> &middot; <%= result.response_time %> ms<% end %>
                  <% if result.error_message.present? %> &middot; <span class="text-red-600"><%= result.error_message %></span><% end %>
                </p>
              </div>
              <span class="text-xs text-slate-400"><%= time_ago_in_words(result.checked_at) %> ago</span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <%# Monitor Details %>
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-base font-semibold text-slate-900">Configuration</h3>
        <dl class="mt-4 space-y-3">
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Type</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.monitor_type.capitalize %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Interval</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.interval %>s</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Timeout</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.timeout %>s</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Retries</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.retries %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Alert Threshold</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.alert_threshold %></dd>
          </div>
          <% if @monitor.http_method.present? %>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">HTTP Method</dt>
              <dd class="text-sm font-medium text-slate-900"><%= @monitor.http_method %></dd>
            </div>
          <% end %>
          <% if @monitor.keyword.present? %>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Keyword</dt>
              <dd class="text-sm font-medium text-slate-900"><%= @monitor.keyword %></dd>
            </div>
          <% end %>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Follow Redirects</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.follow_redirects? ? 'Yes' : 'No' %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm text-slate-500">Verify SSL</dt>
            <dd class="text-sm font-medium text-slate-900"><%= @monitor.verify_ssl? ? 'Yes' : 'No' %></dd>
          </div>
          <% if @monitor.last_check_at %>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Last Check</dt>
              <dd class="text-sm font-medium text-slate-900"><%= time_ago_in_words(@monitor.last_check_at) %> ago</dd>
            </div>
          <% end %>
        </dl>
      </div>

      <%# Tags %>
      <% if @monitor.tags.any? %>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-base font-semibold text-slate-900">Tags</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            <% @monitor.tags.each do |tag| %>
              <%= link_to tag_path(tag), class: "inline-flex items-center rounded-full px-3 py-1 text-xs font-medium", style: "background-color: #{tag.color}20; color: #{tag.color}" do %>
                <%= tag.name %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Notification Channels %>
      <% if @monitor.notification_channels.any? %>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-base font-semibold text-slate-900">Notifications</h3>
          <div class="mt-3 space-y-2">
            <% @monitor.notification_channels.each do |channel| %>
              <%= link_to notification_channel_path(channel), class: "flex items-center gap-2 text-sm text-slate-700 hover:text-slate-900" do %>
                <span class="h-2 w-2 rounded-full <%= channel.enabled? ? 'bg-emerald-500' : 'bg-slate-300' %>"></span>
                <%= channel.name %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Incidents %>
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
          <h3 class="text-base font-semibold text-slate-900">Recent Incidents</h3>
        </div>
        <% if @incidents.any? %>
          <div class="divide-y divide-slate-100">
            <% @incidents.each do |incident| %>
              <%= link_to incident_path(incident), class: "block px-6 py-3 hover:bg-slate-50 transition-colors" do %>
                <div class="flex items-center gap-2">
                  <span class="h-2 w-2 rounded-full <%= incident.ongoing? ? 'bg-red-500' : 'bg-emerald-500' %>"></span>
                  <span class="text-sm font-medium text-slate-900"><%= incident.cause.presence || "Incident" %></span>
                </div>
                <p class="mt-0.5 text-xs text-slate-500">
                  <%= incident.started_at.strftime('%b %d, %Y %H:%M') %>
                  <% if incident.resolved_at %> &middot; Resolved<% end %>
                </p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center">
            <p class="text-sm text-slate-500">No incidents</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
