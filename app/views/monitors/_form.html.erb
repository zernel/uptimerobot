<%= form_with(model: monitor, class: "space-y-8") do |form| %>
  <% if monitor.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(monitor.errors.count, "error") %> prohibited this monitor from being saved:</h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
            <% monitor.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Basic Information %>
  <div>
    <h3 class="text-base font-semibold text-slate-900">Basic Information</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "My Website" %>
      </div>

      <div>
        <%= form.label :monitor_type, "Monitor Type", class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :monitor_type, Monitor.monitor_types.keys.map { |t| [t.capitalize, t] }, {}, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :monitor_group_id, "Group", class: "block text-sm font-medium text-slate-700" %>
        <%= form.collection_select :monitor_group_id, monitor_groups, :id, :name, { include_blank: "No group" }, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :description, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :description, rows: 2, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "Optional description..." %>
      </div>
    </div>
  </div>

  <%# Connection Settings %>
  <div>
    <h3 class="text-base font-semibold text-slate-900">Connection</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= form.label :url, "URL", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :url, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "https://example.com" %>
      </div>

      <div>
        <%= form.label :hostname, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :hostname, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "example.com" %>
      </div>

      <div>
        <%= form.label :port, class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :port, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "443" %>
      </div>

      <div>
        <%= form.label :http_method, "HTTP Method", class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :http_method, %w[GET HEAD POST PUT PATCH DELETE], {}, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :dns_record_type, "DNS Record Type", class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :dns_record_type, %w[A AAAA CNAME MX NS TXT SOA], { include_blank: "Select..." }, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :keyword, "Keyword", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :keyword, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "Expected keyword in response" %>
      </div>

      <div>
        <%= form.label :keyword_type, "Keyword Type", class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :keyword_type, %w[exists not_exists], { include_blank: "Select..." }, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div class="flex items-center gap-3">
        <div class="flex items-center">
          <%= form.check_box :follow_redirects, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
          <%= form.label :follow_redirects, "Follow Redirects", class: "ml-2 text-sm text-slate-700" %>
        </div>
        <div class="flex items-center">
          <%= form.check_box :verify_ssl, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
          <%= form.label :verify_ssl, "Verify SSL", class: "ml-2 text-sm text-slate-700" %>
        </div>
      </div>
    </div>
  </div>

  <%# Timing Settings %>
  <div>
    <h3 class="text-base font-semibold text-slate-900">Timing</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div>
        <%= form.label :interval, "Check Interval (seconds)", class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :interval, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :timeout, "Timeout (seconds)", class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :timeout, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :retries, class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :retries, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>
    </div>
  </div>

  <%# Alert Settings %>
  <div>
    <h3 class="text-base font-semibold text-slate-900">Alerting</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div>
        <%= form.label :alert_threshold, "Alert Threshold", class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :alert_threshold, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
        <p class="mt-1 text-xs text-slate-500">Consecutive failures before alerting</p>
      </div>

      <div>
        <%= form.label :alert_delay, "Alert Delay (seconds)", class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :alert_delay, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>

      <div>
        <%= form.label :alert_days_before, "Domain Expiry Alert (days)", class: "block text-sm font-medium text-slate-700" %>
        <%= form.number_field :alert_days_before, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>
    </div>
  </div>

  <%# Tags %>
  <div>
    <h3 class="text-base font-semibold text-slate-900">Tags</h3>
    <div class="mt-4 flex flex-wrap gap-3">
      <% tags.each do |tag| %>
        <label class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm cursor-pointer hover:bg-slate-50 transition-colors">
          <%= check_box_tag "monitor[tag_ids][]", tag.id, monitor.tag_ids.include?(tag.id), class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>">
            <%= tag.name %>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <%# Submit %>
  <div class="flex items-center justify-end gap-3 border-t border-slate-200 pt-6">
    <%= link_to "Cancel", monitor.persisted? ? monitor_path(monitor) : monitors_path, class: "rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors" %>
    <%= form.submit class: "rounded-lg bg-slate-900 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors cursor-pointer" %>
  </div>
<% end %>
