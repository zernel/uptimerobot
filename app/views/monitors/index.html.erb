<% content_for(:page_title) { "Monitors" } %>

<% content_for(:page_actions) do %>
  <%= link_to new_monitor_path, class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Add Monitor
  <% end %>
<% end %>

<div class="space-y-6" data-controller="search">
  <%# Filters %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="relative flex-1 max-w-md">
      <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
      <input type="text" placeholder="Search monitors..." data-search-target="input" data-action="input->search#search" class="w-full rounded-lg border border-slate-300 bg-white py-2.5 pl-10 pr-4 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500">
    </div>

    <div class="flex items-center gap-2">
      <button data-action="click->search#filterByStatus" data-status="all" class="inline-flex items-center rounded-lg bg-slate-900 px-3 py-2 text-xs font-medium text-white">
        All
      </button>
      <button data-action="click->search#filterByStatus" data-status="up" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-medium text-slate-700">
        <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
        Up
      </button>
      <button data-action="click->search#filterByStatus" data-status="down" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-medium text-slate-700">
        <span class="h-2 w-2 rounded-full bg-red-500"></span>
        Down
      </button>
      <button data-action="click->search#filterByStatus" data-status="paused" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-medium text-slate-700">
        <span class="h-2 w-2 rounded-full bg-amber-500"></span>
        Paused
      </button>
    </div>
  </div>

  <%# Monitor List %>
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    <% if @monitors.any? %>
      <div class="divide-y divide-slate-100">
        <% @monitors.each do |monitor| %>
          <div data-search-target="result" data-status="<%= monitor.status %>" class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
            <%# Status indicator %>
            <div class="flex h-10 w-10 items-center justify-center rounded-full
              <%= case monitor.status
                  when 'up' then 'bg-emerald-100'
                  when 'down' then 'bg-red-100'
                  when 'paused' then 'bg-amber-100'
                  else 'bg-slate-100'
                  end %>">
              <div class="h-3 w-3 rounded-full
                <%= case monitor.status
                    when 'up' then 'bg-emerald-500'
                    when 'down' then 'bg-red-500'
                    when 'paused' then 'bg-amber-500'
                    else 'bg-slate-400'
                    end %>"></div>
            </div>

            <%# Monitor info %>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <%= link_to monitor.name, monitor_path(monitor), class: "text-sm font-medium text-slate-900 hover:text-slate-700" %>
                <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
                  <%= monitor.monitor_type.upcase %>
                </span>
              </div>
              <p class="mt-0.5 truncate text-xs text-slate-500">
                <%= monitor.url.presence || monitor.hostname.presence || "—" %>
              </p>
            </div>

            <%# Tags %>
            <div class="hidden items-center gap-1 sm:flex">
              <% monitor.tags.each do |tag| %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>">
                  <%= tag.name %>
                </span>
              <% end %>
            </div>

            <%# Uptime %>
            <div class="hidden text-right sm:block">
              <% if monitor.uptime_24h %>
                <p class="text-sm font-medium <%= monitor.uptime_24h >= 99 ? 'text-emerald-600' : monitor.uptime_24h >= 95 ? 'text-amber-600' : 'text-red-600' %>">
                  <%= monitor.uptime_24h %>%
                </p>
                <p class="text-xs text-slate-400">24h uptime</p>
              <% else %>
                <p class="text-sm text-slate-400">—</p>
              <% end %>
            </div>

            <%# Response time %>
            <div class="hidden text-right md:block">
              <% if monitor.response_time %>
                <p class="text-sm font-medium text-slate-700"><%= monitor.response_time %> ms</p>
                <p class="text-xs text-slate-400">response</p>
              <% else %>
                <p class="text-sm text-slate-400">—</p>
              <% end %>
            </div>

            <%# Actions %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle" class="rounded-lg p-2 text-slate-400 hover:bg-slate-100 hover:text-slate-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM12.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM18.75 12a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
                </svg>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 z-10 mt-1 w-48 rounded-lg bg-white py-1 shadow-lg ring-1 ring-slate-200">
                <%= link_to "View details", monitor_path(monitor), class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
                <%= link_to "Edit", edit_monitor_path(monitor), class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
                <% if monitor.paused? %>
                  <%= button_to "Resume", resume_monitor_path(monitor), method: :post, class: "block w-full text-left px-4 py-2 text-sm text-emerald-700 hover:bg-slate-50" %>
                <% else %>
                  <%= button_to "Pause", pause_monitor_path(monitor), method: :post, class: "block w-full text-left px-4 py-2 text-sm text-amber-700 hover:bg-slate-50" %>
                <% end %>
                <%= button_to "Delete", monitor_path(monitor), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-slate-50" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
        </svg>
        <p class="mt-3 text-sm font-medium text-slate-500">No monitors yet</p>
        <p class="mt-1 text-xs text-slate-400">Get started by creating your first monitor</p>
        <%= link_to "Add Monitor", new_monitor_path, class: "mt-4 inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" %>
      </div>
    <% end %>
  </div>

  <%# Empty search state %>
  <div data-search-target="empty" class="hidden rounded-xl border border-slate-200 bg-white px-6 py-16 text-center shadow-sm">
    <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
    </svg>
    <p class="mt-3 text-sm font-medium text-slate-500">No monitors found</p>
    <p class="mt-1 text-xs text-slate-400">Try adjusting your search or filter</p>
  </div>

  <%# Pagination %>
  <% if @monitors.respond_to?(:total_pages) && @monitors.total_pages > 1 %>
    <div class="flex justify-center">
      <%= paginate @monitors %>
    </div>
  <% end %>
</div>
