<% content_for(:page_title) { "Incidents" } %>

<div class="space-y-6" data-controller="search">
  <%# Filters %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="relative flex-1 max-w-md">
      <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
      <input type="text" placeholder="Search incidents..." data-search-target="input" data-action="input->search#search" class="w-full rounded-lg border border-slate-300 bg-white py-2.5 pl-10 pr-4 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500">
    </div>

    <div class="flex items-center gap-2">
      <%= link_to "All", incidents_path, class: "inline-flex items-center rounded-lg px-3 py-2 text-xs font-medium #{params[:status].blank? ? 'bg-slate-900 text-white' : 'border border-slate-300 bg-white text-slate-700'}" %>
      <%= link_to "Ongoing", incidents_path(status: 'ongoing'), class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-xs font-medium #{params[:status] == 'ongoing' ? 'bg-slate-900 text-white' : 'border border-slate-300 bg-white text-slate-700'}" %>
      <%= link_to "Resolved", incidents_path(status: 'resolved'), class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-xs font-medium #{params[:status] == 'resolved' ? 'bg-slate-900 text-white' : 'border border-slate-300 bg-white text-slate-700'}" %>
    </div>
  </div>

  <%# Incidents List %>
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    <% if @incidents.any? %>
      <div class="divide-y divide-slate-100">
        <% @incidents.each do |incident| %>
          <%= link_to incident_path(incident), data: { search_target: "result" }, class: "flex items-center gap-4 px-6 py-5 hover:bg-slate-50 transition-colors" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-full <%= incident.ongoing? ? 'bg-red-100' : 'bg-emerald-100' %>">
              <% if incident.ongoing? %>
                <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
              <% else %>
                <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              <% end %>
            </div>

            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <p class="text-sm font-medium text-slate-900"><%= incident.monitor.name %></p>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= incident.ongoing? ? 'bg-red-100 text-red-800' : 'bg-emerald-100 text-emerald-800' %>">
                  <%= incident.status.capitalize %>
                </span>
              </div>
              <p class="mt-0.5 text-xs text-slate-500">
                <% if incident.cause.present? %><%= incident.cause %> &middot; <% end %>
                Started <%= time_ago_in_words(incident.started_at) %> ago
                <% if incident.resolved_at %> &middot; Duration: <%= distance_of_time_in_words(incident.started_at, incident.resolved_at) %><% end %>
              </p>
            </div>

            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="mt-3 text-sm font-medium text-slate-500">No incidents found</p>
        <p class="mt-1 text-xs text-slate-400">That's a good thing!</p>
      </div>
    <% end %>
  </div>

  <% if @incidents.respond_to?(:total_pages) && @incidents.total_pages > 1 %>
    <div class="flex justify-center">
      <%= paginate @incidents %>
    </div>
  <% end %>
</div>
