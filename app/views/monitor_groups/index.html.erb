<% content_for(:page_title) { "Monitor Groups" } %>

<% content_for(:page_actions) do %>
  <%= link_to new_monitor_group_path, class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    New Group
  <% end %>
<% end %>

<div class="space-y-6">
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    <% if @monitor_groups.any? %>
      <div class="divide-y divide-slate-100">
        <% @monitor_groups.each do |group| %>
          <%= link_to monitor_group_path(group), class: "flex items-center gap-4 px-6 py-5 hover:bg-slate-50 transition-colors" do %>
            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-slate-100">
              <svg class="h-6 w-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
              </svg>
            </div>

            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-slate-900"><%= group.name %></p>
              <% if group.description.present? %>
                <p class="mt-0.5 text-xs text-slate-500"><%= truncate(group.description, length: 100) %></p>
              <% end %>
            </div>

            <div class="flex items-center gap-3">
              <span class="text-sm text-slate-500"><%= group.monitors.size %> monitors</span>
              <div class="flex gap-1">
                <% up_count = group.monitors.select { |m| m.status == 'up' }.size %>
                <% down_count = group.monitors.select { |m| m.status == 'down' }.size %>
                <% if up_count > 0 %>
                  <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-1.5 py-0.5 text-xs text-emerald-700">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                    <%= up_count %>
                  </span>
                <% end %>
                <% if down_count > 0 %>
                  <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-1.5 py-0.5 text-xs text-red-700">
                    <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                    <%= down_count %>
                  </span>
                <% end %>
              </div>
            </div>

            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
        </svg>
        <p class="mt-3 text-sm font-medium text-slate-500">No groups yet</p>
        <p class="mt-1 text-xs text-slate-400">Organize your monitors into groups</p>
        <%= link_to "Create Group", new_monitor_group_path, class: "mt-4 inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" %>
      </div>
    <% end %>
  </div>
</div>
