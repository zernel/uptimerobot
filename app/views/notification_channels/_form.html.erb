<%= form_with(model: notification_channel, class: "space-y-6") do |form| %>
  <% if notification_channel.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(notification_channel.errors.count, "error") %> prohibited this channel from being saved:</h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
            <% notification_channel.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "My Email Alerts" %>
  </div>

  <div>
    <%= form.label :channel_type, "Channel Type", class: "block text-sm font-medium text-slate-700" %>
    <%= form.select :channel_type, NotificationChannel.channel_types.keys.map { |t| [t.capitalize, t] }, {}, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
  </div>

  <div>
    <label class="flex items-center gap-3">
      <%= form.check_box :enabled, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
      <span class="text-sm text-slate-700">Enabled</span>
    </label>
  </div>

  <div>
    <h3 class="text-base font-semibold text-slate-900">Configuration</h3>
    <div class="mt-4 space-y-4">
      <div>
        <label for="notification_channel_config_address" class="block text-sm font-medium text-slate-700">Email Address</label>
        <input type="email" name="notification_channel[config][address]" id="notification_channel_config_address"
          value="<%= notification_channel.config&.dig('address') %>"
          class="mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500"
          placeholder="alerts@example.com">
      </div>

      <div>
        <label for="notification_channel_config_webhook_url" class="block text-sm font-medium text-slate-700">Webhook URL</label>
        <input type="url" name="notification_channel[config][webhook_url]" id="notification_channel_config_webhook_url"
          value="<%= notification_channel.config&.dig('webhook_url') %>"
          class="mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500"
          placeholder="https://hooks.slack.com/...">
      </div>

      <div>
        <label for="notification_channel_config_channel" class="block text-sm font-medium text-slate-700">Channel / Room</label>
        <input type="text" name="notification_channel[config][channel]" id="notification_channel_config_channel"
          value="<%= notification_channel.config&.dig('channel') %>"
          class="mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500"
          placeholder="#alerts">
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-slate-200 pt-6">
    <%= link_to "Cancel", notification_channel.persisted? ? notification_channel_path(notification_channel) : notification_channels_path, class: "rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors" %>
    <%= form.submit class: "rounded-lg bg-slate-900 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors cursor-pointer" %>
  </div>
<% end %>
