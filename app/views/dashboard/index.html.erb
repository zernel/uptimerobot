<% content_for(:page_title) { "Dashboard" } %>

<% content_for(:page_actions) do %>
  <%= link_to new_monitor_path, class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    Add Monitor
  <% end %>
<% end %>

<div class="space-y-8">
  <%# Stats Cards %>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Total Monitors</p>
      <p class="mt-2 text-3xl font-bold text-slate-900"><%= @stats[:total] %></p>
    </div>

    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-5 shadow-sm">
      <div class="flex items-center gap-2">
        <div class="h-2.5 w-2.5 rounded-full bg-emerald-500"></div>
        <p class="text-sm font-medium text-emerald-700">Up</p>
      </div>
      <p class="mt-2 text-3xl font-bold text-emerald-900"><%= @stats[:up] %></p>
    </div>

    <div class="rounded-xl border border-red-200 bg-red-50 p-5 shadow-sm">
      <div class="flex items-center gap-2">
        <div class="h-2.5 w-2.5 rounded-full bg-red-500"></div>
        <p class="text-sm font-medium text-red-700">Down</p>
      </div>
      <p class="mt-2 text-3xl font-bold text-red-900"><%= @stats[:down] %></p>
    </div>

    <div class="rounded-xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
      <div class="flex items-center gap-2">
        <div class="h-2.5 w-2.5 rounded-full bg-amber-500"></div>
        <p class="text-sm font-medium text-amber-700">Paused</p>
      </div>
      <p class="mt-2 text-3xl font-bold text-amber-900"><%= @stats[:paused] %></p>
    </div>

    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5 shadow-sm">
      <div class="flex items-center gap-2">
        <div class="h-2.5 w-2.5 rounded-full bg-slate-400"></div>
        <p class="text-sm font-medium text-slate-600">Pending</p>
      </div>
      <p class="mt-2 text-3xl font-bold text-slate-900"><%= @stats[:pending] %></p>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-3">
    <%# Active Incidents %>
    <div class="lg:col-span-2">
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
          <h2 class="text-base font-semibold text-slate-900">Active Incidents</h2>
          <% if @active_incidents.any? %>
            <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">
              <%= @active_incidents.size %> active
            </span>
          <% end %>
        </div>

        <% if @active_incidents.any? %>
          <div class="divide-y divide-slate-100">
            <% @active_incidents.each do |incident| %>
              <%= link_to incident_path(incident), class: "flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors" do %>
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-100">
                  <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-sm font-medium text-slate-900"><%= incident.monitor.name %></p>
                  <p class="text-xs text-slate-500">
                    Started <%= time_ago_in_words(incident.started_at) %> ago
                    <% if incident.cause.present? %> &middot; <%= incident.cause %><% end %>
                  </p>
                </div>
                <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700">
                  Ongoing
                </span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="mt-3 text-sm font-medium text-slate-500">No active incidents</p>
            <p class="mt-1 text-xs text-slate-400">All monitors are running smoothly</p>
          </div>
        <% end %>
      </div>

      <%# Recent Incidents %>
      <% if @recent_incidents.any? %>
        <div class="mt-6 rounded-xl border border-slate-200 bg-white shadow-sm">
          <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
            <h2 class="text-base font-semibold text-slate-900">Recent Incidents</h2>
            <%= link_to "View all", incidents_path, class: "text-sm font-medium text-slate-500 hover:text-slate-700" %>
          </div>
          <div class="divide-y divide-slate-100">
            <% @recent_incidents.each do |incident| %>
              <%= link_to incident_path(incident), class: "flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors" do %>
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100">
                  <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-sm font-medium text-slate-900"><%= incident.monitor.name %></p>
                  <p class="text-xs text-slate-500">
                    Resolved <%= time_ago_in_words(incident.resolved_at) %> ago &middot; Duration: <%= distance_of_time_in_words(incident.started_at, incident.resolved_at) %>
                  </p>
                </div>
                <span class="inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700">
                  Resolved
                </span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Monitor Groups Overview %>
    <div>
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
          <h2 class="text-base font-semibold text-slate-900">Monitor Groups</h2>
          <%= link_to "View all", monitor_groups_path, class: "text-sm font-medium text-slate-500 hover:text-slate-700" %>
        </div>

        <% if @monitor_groups.any? %>
          <div class="divide-y divide-slate-100">
            <% @monitor_groups.each do |group| %>
              <%= link_to monitor_group_path(group), class: "block px-6 py-4 hover:bg-slate-50 transition-colors" do %>
                <p class="text-sm font-medium text-slate-900"><%= group.name %></p>
                <div class="mt-2 flex items-center gap-2">
                  <span class="text-xs text-slate-500"><%= group.monitors.size %> monitors</span>
                  <div class="flex gap-1">
                    <% up_count = group.monitors.select { |m| m.status == 'up' }.size %>
                    <% down_count = group.monitors.select { |m| m.status == 'down' }.size %>
                    <% if up_count > 0 %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-1.5 py-0.5 text-xs text-emerald-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        <%= up_count %>
                      </span>
                    <% end %>
                    <% if down_count > 0 %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-1.5 py-0.5 text-xs text-red-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                        <%= down_count %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center">
            <p class="text-sm text-slate-500">No groups yet</p>
          </div>
        <% end %>
      </div>

      <%# Quick Actions %>
      <div class="mt-6 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-4">
          <h2 class="text-base font-semibold text-slate-900">Quick Actions</h2>
        </div>
        <div class="p-4 space-y-2">
          <%= link_to new_monitor_path, class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add new monitor
          <% end %>
          <%= link_to status_pages_path, class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
            </svg>
            View status pages
          <% end %>
          <%= link_to new_notification_channel_path, class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
            Add notification channel
          <% end %>
          <%= link_to new_maintenance_window_path, class: "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Schedule maintenance
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
