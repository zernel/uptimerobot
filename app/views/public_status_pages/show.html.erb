<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= @status_page.name %> - Status</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <% if @status_page.noindex? %>
      <meta name="robots" content="noindex">
    <% end %>
    <% if @status_page.favicon_url.present? %>
      <link rel="icon" href="<%= @status_page.favicon_url %>">
    <% end %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <% if @status_page.google_analytics_id.present? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= @status_page.google_analytics_id %>"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '<%= @status_page.google_analytics_id %>');
      </script>
    <% end %>
  </head>

  <body class="h-full bg-slate-50 font-sans antialiased">
    <%# Header %>
    <header class="border-b border-slate-200" style="background-color: <%= @status_page.header_bg_color || '#1F2937' %>">
      <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4">
          <% if @status_page.logo_url.present? %>
            <img src="<%= @status_page.logo_url %>" alt="<%= @status_page.name %>" class="h-10 w-auto">
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-white"><%= @status_page.name %></h1>
            <p class="mt-1 text-sm text-slate-300">Service Status</p>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
      <%# Overall Status %>
      <% all_up = @monitors.all? { |m| m.status == 'up' } %>
      <% any_down = @monitors.any? { |m| m.status == 'down' } %>

      <div class="rounded-xl border p-6 mb-8
        <%= if all_up
            'border-emerald-200 bg-emerald-50'
          elsif any_down
            'border-red-200 bg-red-50'
          else
            'border-amber-200 bg-amber-50'
          end %>">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-full
            <%= if all_up
                'bg-emerald-100'
              elsif any_down
                'bg-red-100'
              else
                'bg-amber-100'
              end %>">
            <% if all_up %>
              <svg class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            <% elsif any_down %>
              <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
              </svg>
            <% else %>
              <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
            <% end %>
          </div>
          <div>
            <h2 class="text-lg font-semibold
              <%= if all_up
                  'text-emerald-900'
                elsif any_down
                  'text-red-900'
                else
                  'text-amber-900'
                end %>">
              <%= if all_up
                  'All Systems Operational'
                elsif any_down
                  'Some Systems Are Experiencing Issues'
                else
                  'Partial System Disruption'
                end %>
            </h2>
            <p class="text-sm
              <%= if all_up
                  'text-emerald-700'
                elsif any_down
                  'text-red-700'
                else
                  'text-amber-700'
                end %>">
              Last updated just now
            </p>
          </div>
        </div>
      </div>

      <%# Active Announcements %>
      <% if @active_announcements.any? %>
        <div class="mb-8 space-y-4">
          <% @active_announcements.each do |announcement| %>
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                  <%= case announcement.status
                      when 'investigating' then 'bg-red-100 text-red-800'
                      when 'identified' then 'bg-amber-100 text-amber-800'
                      when 'monitoring' then 'bg-blue-100 text-blue-800'
                      else 'bg-slate-100 text-slate-600'
                      end %>">
                  <%= announcement.status.capitalize %>
                </span>
                <span class="text-xs text-slate-500"><%= time_ago_in_words(announcement.started_at) %> ago</span>
              </div>
              <h3 class="text-base font-semibold text-slate-900"><%= announcement.title %></h3>
              <p class="mt-2 text-sm text-slate-700"><%= announcement.content %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Monitors %>
      <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="divide-y divide-slate-100">
          <% @monitors.each do |monitor| %>
            <div class="flex items-center gap-4 px-6 py-5">
              <div class="h-3 w-3 rounded-full
                <%= case monitor.status
                    when 'up' then 'bg-emerald-500'
                    when 'down' then 'bg-red-500'
                    when 'paused' then 'bg-amber-500'
                    else 'bg-slate-400'
                    end %>"></div>

              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-slate-900"><%= monitor.name %></p>
                <% if @status_page.show_monitor_url? && monitor.url.present? %>
                  <p class="text-xs text-slate-500"><%= monitor.url %></p>
                <% end %>
              </div>

              <% if @status_page.show_uptime_percentage? && monitor.uptime_30d %>
                <div class="hidden text-right sm:block">
                  <p class="text-sm font-medium
                    <%= monitor.uptime_30d >= 99 ? 'text-emerald-600' : monitor.uptime_30d >= 95 ? 'text-amber-600' : 'text-red-600' %>">
                    <%= monitor.uptime_30d %>%
                  </p>
                  <p class="text-xs text-slate-400">uptime</p>
                </div>
              <% end %>

              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                <%= case monitor.status
                    when 'up' then 'bg-emerald-100 text-emerald-800'
                    when 'down' then 'bg-red-100 text-red-800'
                    when 'paused' then 'bg-amber-100 text-amber-800'
                    else 'bg-slate-100 text-slate-600'
                    end %>">
                <%= monitor.status.capitalize %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Resolved Announcements %>
      <% if @resolved_announcements.any? %>
        <div class="mt-8">
          <h3 class="text-base font-semibold text-slate-900 mb-4">Past Incidents</h3>
          <div class="space-y-4">
            <% @resolved_announcements.each do |announcement| %>
              <div class="rounded-xl border border-slate-200 bg-white p-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800">
                    Resolved
                  </span>
                  <span class="text-xs text-slate-500"><%= announcement.resolved_at&.strftime('%b %d, %Y') %></span>
                </div>
                <h4 class="text-sm font-semibold text-slate-900"><%= announcement.title %></h4>
                <p class="mt-1 text-sm text-slate-600"><%= truncate(announcement.content, length: 200) %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </main>

    <footer class="border-t border-slate-200 bg-white mt-12">
      <div class="mx-auto max-w-4xl px-4 py-6 sm:px-6 lg:px-8 text-center">
        <p class="text-xs text-slate-400">Powered by UptimeRobot</p>
      </div>
    </footer>
  </body>
</html>
